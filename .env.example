# ============================================================
# Halo Chat FE — Environment template
# Copy thành `.env.local` khi dev local. Khi deploy Vercel:
# vào Project → Settings → Environment Variables và điền từng key.
# CHỈ commit file .env.example này — KHÔNG commit .env/.env.local.
# ============================================================

# ---------- Server-side (next.config.ts dùng cho rewrites proxy) ----------
# Bắt buộc khi build web (BUILD_TARGET != electron). Build sẽ FAIL nếu thiếu.
# URL gốc của backend auth (authen-vibe) và backend chat (vibe-chat).
AUTH_URL=
VIBE_URL=

# ---------- Client-side (NEXT_PUBLIC_* — nhúng vào bundle lúc BUILD) ----------
# Lưu ý Vercel: đổi giá trị NEXT_PUBLIC_* xong phải REDEPLOY mới có hiệu lực.

# true  → client gọi same-origin /api/v1/* và Next rewrites proxy sang BE
#         (khuyến nghị trên Vercel: tránh CORS, giấu URL BE).
# false → client gọi thẳng NEXT_PUBLIC_AUTH_URL / NEXT_PUBLIC_VIBE_URL
#         (bắt buộc với bản Electron static export).
NEXT_PUBLIC_USE_PROXY=true

# Vẫn bắt buộc khai báo kể cả khi dùng proxy (env.ts validate url).
NEXT_PUBLIC_AUTH_URL=
NEXT_PUBLIC_VIBE_URL=

# WebSocket gọi THẲNG tới BE (không qua rewrites proxy được) — dùng wss:// ở prod.
NEXT_PUBLIC_WS_URL=
NEXT_PUBLIC_CALL_WS_URL=

# ---------- Firebase Cloud Messaging (optional — bỏ trống nếu chưa bật push) ----------
# Lấy từ Firebase Console → Project settings → General → Your apps (Web app).
# VAPID key: Project settings → Cloud Messaging → Web Push certificates.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
