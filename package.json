{
  "name": "halo-chat",
  "version": "0.1.1",
  "description": "Halo — desktop messaging app",
  "homepage": "https://github.com/huytq203/halo-chat",
  "author": {
    "name": "huytq203",
    "email": "huytq203@gmail.com"
  },
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "NODE_OPTIONS=\"--max-old-space-size=4096 --dns-result-order=ipv4first\" next dev",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "NODE_OPTIONS=--dns-result-order=ipv4first next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "electron:build": "BUILD_TARGET=electron NODE_OPTIONS=--max-old-space-size=4096 next build && cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/",
    "electron:start": "electron .",
    "electron:dev": "npm run electron:build && electron .",
    "electron:pack:linux": "npm run electron:build && electron-builder --linux deb",
    "electron:pack:win": "npm run electron:build && electron-builder --win nsis",
    "electron:pack:all": "npm run electron:build && electron-builder --linux deb --win nsis"
  },
  "build": {
    "appId": "com.halochat.desktop",
    "productName": "Halo",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      ".next/standalone/**/*",
      "electron/main.js",
      "electron/preload.js",
      "electron/resources/icons/512x512.png"
    ],
    "asar": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/resources/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/resources/icons",
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "deb": {
      "packageCategory": "net",
      "afterInstall": "electron/deb-after-install.sh"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@tiptap/core": "^3.26.1",
    "@tiptap/extension-bold": "^3.26.1",
    "@tiptap/extension-color": "^3.26.1",
    "@tiptap/extension-document": "^3.26.1",
    "@tiptap/extension-font-family": "^3.26.1",
    "@tiptap/extension-highlight": "^3.26.1",
    "@tiptap/extension-history": "^3.26.1",
    "@tiptap/extension-italic": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-mention": "^3.26.1",
    "@tiptap/extension-paragraph": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/extension-strike": "^3.26.1",
    "@tiptap/extension-text": "^3.26.1",
    "@tiptap/extension-text-align": "^3.26.1",
    "@tiptap/extension-text-style": "^3.26.1",
    "@tiptap/extension-underline": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "emoji-picker-react": "^4.19.1",
    "firebase": "^11.0.2",
    "livekit-client": "^2.19.1",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "postcss": "^8.5.14",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-draggable": "^4.6.0",
    "react-hook-form": "^7.75.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss-animate": "^1.0.7",
    "twemoji-parser": "^14.0.0",
    "yet-another-react-lightbox": "^3.32.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.6",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
